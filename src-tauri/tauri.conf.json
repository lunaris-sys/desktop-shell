{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lunaris-desktop-shell",
  "version": "0.1.0",
  "identifier": "dev.lunaris.desktop-shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "lunaris-desktop-shell",
        "width": 1,
        "height": 36,
"visible": false,
        "decorations": false,
        "transparent": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": ["/usr/share/icons/**", "/usr/share/pixmaps/**", "/usr/local/share/icons/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
